# Inline tools registry — ONLY tools listed and enabled here are dispatchable via inline query.
# type: direct  → executor called without LLM
# type: llm     → routes through an LLM executor (disabled tools below show the future interface)
#
# New fields (v2):
#   description:  Plain English summary used by the classifier for embedding-based routing.
#   handles:      List of bot usernames this tool responds to (omit to match all bots).
#   prefix:       Shorthand for a single prefix match rule — equivalent to:
#                   match: [{pattern: "^<prefix>", type: prefix, priority: 0}]
#                 Use this for tools triggered by a leading character/word.
#                 Keep the full match: block for URL and catch-all types.
#
# Routing precedence (lowest priority number wins):
#   prefix tools and URL tools both default to priority 0.
#   Stable sort preserves YAML order for equal-priority tools.
version: 1

tools:
  - id: media_audio
    type: direct
    executor: inline_media_audio
    media_type: audio
    description: "Download a song or audio track — type a song name, artist, or paste a Spotify/YouTube/SoundCloud/Apple Music link"
    # handles: [myinlinebot]   # omit to respond on all bots
    match:
      - pattern: "https?://(open\\.spotify\\.com|music\\.apple\\.com|soundcloud\\.com)"
        type: url
        priority: 0
    timeout_sec: 25
    # Resolved from env at runtime; falls back to user DM if unset.
    staging_chat_env: TELEGRAM_HOME_CHANNEL
    enabled: true

  - id: media_video
    type: direct
    executor: inline_media_video
    media_type: video
    description: "Download a video — type a video title, topic, or paste a YouTube or other video URL"
    # handles: [myinlinebot]   # omit to respond on all bots
    match:
      - pattern: "https?://(youtube\\.com|youtu\\.be)"
        type: url
        priority: 0
    timeout_sec: 45
    # Resolved from env at runtime; falls back to user DM if unset.
    staging_chat_env: TELEGRAM_HOME_CHANNEL
    enabled: true

  - id: repost
    type: direct
    executor: inline_repost
    description: "Search the agent's past messages by keyword and send the result to the current chat"
    # handles: [myinlinebot]   # omit to respond on all bots
    prefix: "#"
    match:
      - pattern: "^#"
        type: prefix
        priority: 0
    timeout_sec: 10
    cache:
      backend: memory
      ttl_sec: 3600
    enabled: true

  # Future LLM tools — disabled until explicitly enabled and model tier verified.

  - id: web_search
    type: llm
    executor: inline_llm
    description: "Search the web and summarise the answer"
    # handles: [myinlinebot]
    prefix: "?"
    model_tier: simple
    match:
      - pattern: "^\\?"
        type: prefix
        priority: 0
    timeout_sec: 20
    cache:
      backend: none
    inline_only: false
    enabled: false

  - id: weather
    type: llm
    executor: inline_llm
    description: "Get current weather for a city or location"
    # handles: [myinlinebot]
    prefix: "weather "
    model_tier: simple
    match:
      - pattern: "^weather\\s+"
        type: prefix
        priority: 0
    timeout_sec: 15
    cache:
      backend: memory
      ttl_sec: 600
    inline_only: false
    enabled: false
