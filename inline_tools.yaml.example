# Inline tools registry — ONLY tools listed and enabled here are dispatchable via inline query.
# type: direct  → executor called without LLM
# type: llm     → routes through Manifest (disabled tools below show the future interface)
#
# New fields (v2):
#   description:  Plain English summary used by the classifier for embedding-based routing.
#   handles:      List of bot usernames this tool responds to (omit to match all bots).
#   prefix:       Shorthand for a single prefix match rule — equivalent to:
#                   match: [{pattern: "^<prefix>", type: prefix, priority: 0}]
#                 Use this for tools triggered by a leading character/word.
#                 Keep the full match: block for URL and catch-all types.
#
# Routing precedence (lowest priority number wins):
#   prefix tools and URL tools both default to priority 0.
#   Stable sort preserves YAML order for equal-priority tools.
#
# #закон routing note: the ^# pattern correctly matches Cyrillic queries like #закон.
# Past failures were at the executor level (FTS5 trigram tokenizer returning no rows
# for short Cyrillic terms), not in the routing layer. The match block is correct as-is.
version: 1

tools:
  - id: media_download
    type: direct
    executor: inline_media
    description: "Download audio from Spotify, YouTube, SoundCloud or Apple Music — paste a link or search by song name"
    # handles: [myinlinebot]   # omit to respond on all bots
    match:
      - pattern: "https?://(open\\.spotify\\.com|music\\.apple\\.com|youtube\\.com|youtu\\.be|soundcloud\\.com)"
        type: url
        priority: 0
    timeout_sec: 25
    cache:
      backend: memory
      ttl_sec: 3600
    # Resolved from env at runtime; falls back to user DM if unset.
    staging_chat_env: TELEGRAM_HOME_CHANNEL
    enabled: true

  - id: repost
    type: direct
    executor: inline_repost
    description: "Search past Aineko messages by keyword and send the result to the current chat"
    # handles: [myinlinebot]   # omit to respond on all bots
    prefix: "#"
    match:
      - pattern: "^#"
        type: prefix
        priority: 0
    timeout_sec: 10
    cache:
      backend: memory
      ttl_sec: 3600
    enabled: true

  # Future LLM tools — disabled until explicitly enabled and model tier verified.

  - id: web_search
    type: llm
    executor: inline_llm
    description: "Search the web and summarise the answer"
    # handles: [myinlinebot]
    prefix: "?"
    model_tier: simple
    match:
      - pattern: "^\\?"
        type: prefix
        priority: 0
    timeout_sec: 20
    cache:
      backend: none
    inline_only: false
    enabled: false

  - id: weather
    type: llm
    executor: inline_llm
    description: "Get current weather for a city or location"
    # handles: [myinlinebot]
    prefix: "weather "
    model_tier: simple
    match:
      - pattern: "^weather\\s+"
        type: prefix
        priority: 0
    timeout_sec: 15
    cache:
      backend: memory
      ttl_sec: 600
    inline_only: false
    enabled: false
